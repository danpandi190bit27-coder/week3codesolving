import java.util.*;

public class Solution {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        
        // Read N (size of BitSets) and M (number of operations)
        int n = sc.nextInt();
        int m = sc.nextInt();
        
        // Initialize two BitSets of size N
        BitSet b1 = new BitSet(n);
        BitSet b2 = new BitSet(n);
        
        // Use an array to easily reference B1 (index 0) and B2 (index 1)
        BitSet[] bitsets = new BitSet[]{b1, b2};
        
        for (int i = 0; i < m; i++) {
            String opcode = sc.next();
            int num1 = sc.nextInt();
            int num2 = sc.nextInt();
            
            // Execute the operation based on opcode
            switch (opcode) {
                case "AND":
                    // bitsets[num1-1] is the left operand, replaced by the result
                    bitsets[num1 - 1].and(bitsets[num2 - 1]);
                    break;
                case "OR":
                    bitsets[num1 - 1].or(bitsets[num2 - 1]);
                    break;
                case "XOR":
                    bitsets[num1 - 1].xor(bitsets[num2 - 1]);
                    break;
                case "FLIP":
                    // Flip the bit at index num2 in BitSet num1
                    bitsets[num1 - 1].flip(num2);
                    break;
                case "SET":
                    // Set the bit at index num2 in BitSet num1
                    bitsets[num1 - 1].set(num2);
                    break;
            }
            
            // cardinality() returns the number of set bits (true)
            System.out.println(b1.cardinality() + " " + b2.cardinality());
        }
        sc.close();
    }
}
